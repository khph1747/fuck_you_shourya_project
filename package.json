{
    "name": "tennis-court-reservation",
    "version": "1.0.0",
    "description": "A modern tennis court reservation and waitlist management app",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "concurrently \"nodemon server.js\" \"cd client && npm start\"",
        "install-all": "npm install && cd client && npm install",
        "build:client": "npm install --prefix client && npm run build --prefix client",
        "build": "npm run build:client",
        "postinstall": "npm run build:client"
    },
    "dependencies": {
        "express": "^4.18.2",
        "cors": "^2.8.5",
        "sql.js": "^1.10.2",
        "qrcode": "^1.5.3",
        "uuid": "^9.0.0",
        "node-cron": "^3.0.3",
        "axios": "^1.6.2"
    },
    "devDependencies": {
        "nodemon": "^3.0.3",
        "concurrently": "^8.2.2"
    }
}
